{
  "name": "studydeck",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "StudyDeck - a focused study session planner built with React and Electron.",
  "author": "Student Name",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --publish never",
    "dist:publish": "npm run build && electron-builder --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.2.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.swe40006.studydeck",
    "productName": "StudyDeck",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/renderer/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "YOUR_REPO_NAME"
      }
    ]
  }
}
